# Port d'écoute du serveur HTTP
PORT=3000

# Secret utilisé pour signer/vérifier les JWT (à remplacer par une valeur forte et unique en production)
JWT_SECRET=change_this_secret_in_production

# Durée de validité des JWT (format vercel/ms : "1h", "7d", "30m", ...)
JWT_EXPIRES_IN=1d

# Chemin du fichier de base de données SQLite (créé automatiquement au démarrage si absent)
DB_PATH=./data/stock.db
